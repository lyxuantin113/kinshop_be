generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// Example User Model
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  role      Role      @default(USER)
  cart      Cart?
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
  discounts   Discount[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("categories")
}

model Product {
  id          String         @id @default(uuid())
  name        String
  slug        String         @unique
  description String?
  price       Decimal        @db.Decimal(10, 2)
  stock       Int            @default(0)
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  discounts   Discount[]
  version     Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  publicId  String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  altText   String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@map("cart_items")
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  subtotal    Decimal     @db.Decimal(10, 2)
  shippingFee Decimal     @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  discountId  String?
  discount    Discount?   @relation(fields: [discountId], references: [id])
  totalAmount Decimal     @db.Decimal(10, 2)
  address     String?
  phoneNumber String?
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([discountId])
  @@map("orders")
}

model Discount {
  id             String       @id @default(uuid())
  code           String       @unique
  type           DiscountType
  value          Decimal      @db.Decimal(10, 2)
  scope          DiscountScope
  productId      String?
  product        Product?     @relation(fields: [productId], references: [id])
  categoryId     String?
  category       Category?    @relation(fields: [categoryId], references: [id])
  minOrderAmount Decimal      @default(0) @db.Decimal(10, 2)
  usageLimit     Int?         // Null means unlimited
  usedCount      Int          @default(0)
  version        Int          @default(0)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(true)
  orders         Order[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("discounts")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountScope {
  GLOBAL
  PRODUCT
  CATEGORY
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  price     Decimal  @db.Decimal(10, 2) // Price at the time of purchase
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  description String?
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}
